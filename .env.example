# ─────────────────────────────────────────────────────────────────────
#  PharmaTrack — Environment Variable Template
#
#  Copy this file to .env and fill in real values before running.
#  NEVER commit .env to version control.
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=pharma_inventory
POSTGRES_USER=pharma
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ── Spring Boot Backend ───────────────────────────────────────────────
# DB_URL is constructed automatically from the postgres variables above
# in docker-compose.yml. Override here only if using an external DB.
# DB_URL=jdbc:postgresql://your-rds-host:5432/pharma_inventory

BACKEND_PORT=8080

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRATION_MS=86400000   # 24 hours in milliseconds

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:80,https://yourdomain.com

# Hibernate DDL mode: update (dev) | validate (prod) | create-drop (test)
DDL_AUTO=update

# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ── React Frontend ────────────────────────────────────────────────────
FRONTEND_PORT=80

# ── Cloud deployment (set these in your CI/CD secrets) ───────────────
# DOCKER_REGISTRY=ghcr.io/your-org
# IMAGE_TAG=latest

# ── Railway (auto-injected when using Railway provider) ──────────────
# DATABASE_URL=postgresql://...   (auto-set by Railway Postgres plugin)
# PORT=8080                       (auto-set by Railway)
